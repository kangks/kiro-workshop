{
  "enabled": true,
  "name": "Vulnerability Guard",
  "description": "Before writing to any DVAIA source file, reminds the agent that this is a deliberately vulnerable workshop app and vulnerabilities must be preserved.",
  "version": "1",
  "when": {
    "type": "preToolUse",
    "toolTypes": [
      "write"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "VULNERABILITY GUARD CHECK: You are about to write to a file in the DVAIA workshop codebase. This is a DELIBERATELY VULNERABLE application for LLM security training. Before proceeding, confirm: (1) Your change does NOT fix any intentional vulnerability (SHA-256 hashing, missing CSRF, SSRF, RAG poisoning, over-privileged agent tools, static MFA codes, hardcoded secrets, missing upload validation, template injection). (2) Your change does NOT add security hardening (bcrypt, input sanitization, auth checks, rate limiting, cookie flags). (3) All existing RED tests will still pass after your change. If your change would fix a vulnerability, STOP and do not proceed. The vulnerabilities are the workshop material."
  }
}